# Alisher Mobile - Environment Variables
# Bu faylni .env deb nomlang va o'z qiymatlaringizni kiriting

# Supabase Database
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Telegram Bot (ixtiyoriy)
VITE_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
VITE_TELEGRAM_CHAT_ID=your_telegram_chat_id

# API Endpoints (ixtiyoriy)
VITE_API_BASE_URL=https://api.alisher-mobile.uz
VITE_CDN_BASE_URL=https://cdn.alisher-mobile.uz

# Analytics (ixtiyoriy) 
VITE_GOOGLE_ANALYTICS_ID=your_ga_id
VITE_YANDEX_METRICA_ID=your_metrica_id

# Payment Gateway (kelajakda)
VITE_PAYME_MERCHANT_ID=your_payme_id
VITE_CLICK_MERCHANT_ID=your_click_id

# Security
VITE_ENCRYPTION_KEY=your_encryption_key_32_chars