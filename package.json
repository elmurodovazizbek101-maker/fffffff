{
  "name": "alisher-mobile",
  "version": "1.0.0",
  "description": "Alisher Mobile - Professional online store for mobile phones",
  "author": "Alisher Mobile Team",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "analyze": "vite build --mode analyze",
    "clean": "rimraf dist node_modules",
    "reinstall": "npm run clean && npm install",
    "bot": "cd bot && node index.js",
    "bot:dev": "cd bot && nodemon index.js",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "lighthouse": "lighthouse http://localhost:5173 --view",
    "pwa:test": "lighthouse http://localhost:5173 --preset=pwa --view"
  },
  "dependencies": {
    "lucide-react": "^0.263.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^6.8.0",
    "recharts": "^2.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.0",
    "nodemon": "^3.0.4",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "terser": "^5.47.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "browserslist": [
    "defaults",
    "IE 11"
  ],
  "keywords": [
    "mobile-shop",
    "ecommerce",
    "react",
    "vite",
    "telegram-bot",
    "pwa",
    "online-store",
    "uzbekistan"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/username/alisher-mobile.git"
  },
  "bugs": {
    "url": "https://github.com/username/alisher-mobile/issues"
  },
  "homepage": "https://alisher-mobile.uz"
}
